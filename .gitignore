# -----------------------------
# Python Core
# -----------------------------
__pycache__/
*.py[cod]
*$py.class

# -----------------------------
# Virtual Environments
# -----------------------------
venv/
env/
.venv/

# -----------------------------
# IDEs and Local Settings
# -----------------------------
.vscode/
.idea/
*.swp
.DS_Store

# -----------------------------
# Geospatial & Large Data Files
# -----------------------------
# Prevent accidentally committing massive rasters or point clouds
*.tif
*.tiff
*.las
*.laz
*.vrt

# Prevent committing intermediate shapefiles
*.shp
*.shx
*.dbf
*.prj

# -----------------------------
# Project Specific Folders
# -----------------------------
# Ignore the output directories generated by the script
temp/
Change/
DTM/
